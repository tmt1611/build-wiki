    <script>
        const toTopBtn = document.getElementById("toTopBtn");
        window.onscroll = function() {
            if (document.body.scrollTop > 100 || document.documentElement.scrollTop > 100) {
                toTopBtn.style.display = "block";
            } else {
                toTopBtn.style.display = "none";
            }
        };
        function scrollToTop() {
            document.body.scrollTop = 0; // For Safari
            document.documentElement.scrollTop = 0; // For Chrome, Firefox, etc.
        }

        // Handle anchor links on page load for smooth scrolling
        document.addEventListener("DOMContentLoaded", function() {
            // The timeout is a hack to ensure the browser has time to potentially
            // jump to the anchor first, before we smooth-scroll.
            setTimeout(function() {
                if (window.location.hash) {
                    try {
                        var element = document.querySelector(decodeURIComponent(window.location.hash));
                        if (element) {
                            element.scrollIntoView({ behavior: 'smooth' });
                        }
                    } catch (e) {
                        console.error("Could not scroll to anchor: ", e);
                    }
                }
            }, 100);
        });

        // In-page search functionality
        (function() {
            const toggleBtn = document.getElementById('page-search-toggle');
            const searchForm = document.getElementById('page-search-form');
            const searchInput = document.getElementById('page-search-input');
            const prevBtn = document.getElementById('page-search-prev');
            const nextBtn = document.getElementById('page-search-next');
            const countEl = document.getElementById('page-search-count');
            const contentBody = document.querySelector('.content-body');
            
            if (!toggleBtn || !searchForm || !contentBody) return;

            let matches = [];
            let currentIndex = -1;
            let originalContent = contentBody.innerHTML;

            toggleBtn.addEventListener('click', function() {
                const isHidden = searchForm.style.display === 'none';
                searchForm.style.display = isHidden ? 'flex' : 'none';
                if (isHidden) {
                    searchInput.focus();
                } else {
                    clearSearch();
                }
            });

            function performSearch() {
                clearSearch(false); // Clear highlights but not input
                const query = searchInput.value.trim();
                if (query.length < 2) {
                    countEl.textContent = '0/0';
                    return;
                }

                const regex = new RegExp(query, 'gi');
                const walker = document.createTreeWalker(contentBody, NodeFilter.SHOW_TEXT, null, false);
                let node;
                let textNodes = [];
                while (node = walker.nextNode()) {
                    if (node.parentElement.tagName !== 'SCRIPT' && node.parentElement.tagName !== 'STYLE') {
                         if (regex.test(node.nodeValue)) {
                            textNodes.push(node);
                        }
                    }
                }

                textNodes.forEach(node => {
                    const span = document.createElement('span');
                    span.innerHTML = node.nodeValue.replace(regex, match => `<mark class="search-highlight">${match}</mark>`);
                    node.parentNode.replaceChild(span, node);
                });

                matches = contentBody.querySelectorAll('.search-highlight');
                updateCount();
                if (matches.length > 0) {
                    currentIndex = 0;
                    scrollToMatch(currentIndex);
                }
            }

            function clearSearch(clearInput = true) {
                // This is a bit brute-force but reliable for restoring original state.
                contentBody.innerHTML = originalContent;
                matches = [];
                currentIndex = -1;
                if (clearInput) {
                    searchInput.value = '';
                }
                updateCount();
            }
            
            function updateCount() {
                if (matches.length > 0) {
                    countEl.textContent = `${currentIndex + 1}/${matches.length}`;
                } else {
                    countEl.textContent = '0/0';
                }
            }

            function scrollToMatch(index) {
                if (index < 0 || index >= matches.length) return;
                
                matches.forEach(m => m.classList.remove('active'));
                const match = matches[index];
                match.classList.add('active');
                match.scrollIntoView({ behavior: 'smooth', block: 'center' });
                currentIndex = index;
                updateCount();
            }

            let searchTimeout;
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(performSearch, 300);
            });
            
            searchForm.addEventListener('submit', (e) => {
                e.preventDefault();
                performSearch();
            });

            nextBtn.addEventListener('click', function() {
                if (matches.length > 0) {
                    const nextIndex = (currentIndex + 1) % matches.length;
                    scrollToMatch(nextIndex);
                }
            });
            
            prevBtn.addEventListener('click', function() {
                if (matches.length > 0) {
                    const prevIndex = (currentIndex - 1 + matches.length) % matches.length;
                    scrollToMatch(prevIndex);
                }
            });

        })();
    </script>

