                clearSearch(false); // Clear highlights but not input
                const query = searchInput.value.trim();
                if (query.length < 2) {
                    countEl.textContent = '0/0';
                    return;
                }

                const regex = new RegExp(query, 'gi');
                const walker = document.createTreeWalker(contentBody, NodeFilter.SHOW_TEXT, null, false);
                let node;
                let textNodes = [];
                while (node = walker.nextNode()) {
                    if (node.parentElement.tagName !== 'SCRIPT' && node.parentElement.tagName !== 'STYLE') {
                         if (regex.test(node.nodeValue)) {
                            textNodes.push(node);
                        }
                    }
                }

                textNodes.forEach(node => {
                    const span = document.createElement('span');
                    span.innerHTML = node.nodeValue.replace(regex, match => `<mark class="search-highlight">${match}</mark>`);
                    node.parentNode.replaceChild(span, node);
                });

                matches = contentBody.querySelectorAll('.search-highlight');
                updateCount();
                if (matches.length > 0) {
                    currentIndex = 0;
                    scrollToMatch(currentIndex);
                }
            }

            function clearSearch(clearInput = true) {
                // This is a bit brute-force but reliable for restoring original state.
                contentBody.innerHTML = originalContent;
                matches = [];
                currentIndex = -1;
                if (clearInput) {
                    searchInput.value = '';
                }
                updateCount();
            }
            
            function updateCount() {
                if (matches.length > 0) {
                    countEl.textContent = `${currentIndex + 1}/${matches.length}`;
                } else {
                    countEl.textContent = '0/0';
                }
            }

            function scrollToMatch(index) {
                if (index < 0 || index >= matches.length) return;
                
                matches.forEach(m => m.classList.remove('active'));
                const match = matches[index];
                match.classList.add('active');
                match.scrollIntoView({ behavior: 'smooth', block: 'center' });
                currentIndex = index;
                updateCount();
            }

            let searchTimeout;
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(performSearch, 300);
            });
            
            searchForm.addEventListener('submit', (e) => {
                e.preventDefault();
                performSearch();
            });

            nextBtn.addEventListener('click', function() {
                if (matches.length > 0) {
                    const nextIndex = (currentIndex + 1) % matches.length;
                    scrollToMatch(nextIndex);
                }
            });
            
            prevBtn.addEventListener('click', function() {
                if (matches.length > 0) {
                    const prevIndex = (currentIndex - 1 + matches.length) % matches.length;
                    scrollToMatch(prevIndex);
                }
            });

        })();
    </script>

</body>
</html>